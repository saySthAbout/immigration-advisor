# 이 파일을 core-api/.env 로 복사한 뒤 실제 값을 채우세요.
# .env는 .gitignore 처리되어 있어 커밋되지 않습니다.

DATABASE_URL=postgresql+psycopg2://user:password@localhost:5432/immigration_advisor

# ml-service HF Space에 설정한 것과 정확히 동일한 값이어야 한다.
INTERNAL_SERVICE_TOKEN=change-me-to-a-random-secret

# 배포된 ml-service의 실제 HF Space 도메인
ML_SERVICE_URL=https://your-username-immigration-advisor-ml.hf.space

# 프론트엔드가 실제로 배포되는 origin을 콤마로 구분해서 나열 (와일드카드 금지)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost
