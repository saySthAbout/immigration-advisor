/dl-service/.git/
/llm-service/.git/

# raw/processed datasets - too large/messy for git, scripts reproduce them
/dataset/
/*/data/raw/
/*/data/processed/
/*/models/

# env/secrets
.env
*/.env
!*/.env.example
.internal_service_token.local

